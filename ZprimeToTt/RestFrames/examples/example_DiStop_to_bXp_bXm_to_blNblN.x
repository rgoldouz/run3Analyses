func_lt_dump_args ()
{
  lt_dump_args_N=1;
  for lt_arg
  do
    $ECHO "example_DiStop_to_bXp_bXm_to_blNblN.x:example_DiStop_to_bXp_bXm_to_blNblN.x:$LINENO: newargv[$lt_dump_args_N]: $lt_arg"
    lt_dump_args_N=`expr $lt_dump_args_N + 1`
  done
}

# Core function for launching the target application
func_exec_program_core ()
{

      if test -n "$lt_option_debug"; then
        $ECHO "example_DiStop_to_bXp_bXm_to_blNblN.x:example_DiStop_to_bXp_bXm_to_blNblN.x:$LINENO: newargv[0]: $progdir/$program" 1>&2
