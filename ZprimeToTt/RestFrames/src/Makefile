	cd $(top_builddir) && $(MAKE) $(AM_MAKEFLAGS) am--refresh
$(am__aclocal_m4_deps):

install-RestFrameslibLTLIBRARIES: $(RestFrameslib_LTLIBRARIES)
	@$(NORMAL_INSTALL)
	@list='$(RestFrameslib_LTLIBRARIES)'; test -n "$(RestFrameslibdir)" || list=; \
	list2=; for p in $$list; do \
	  if test -f $$p; then \
	    list2="$$list2 $$p"; \
	  else :; fi; \
	done; \
	test -z "$$list2" || { \
	  echo " $(MKDIR_P) '$(DESTDIR)$(RestFrameslibdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(RestFrameslibdir)" || exit 1; \
	  echo " $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=install $(INSTALL) $(INSTALL_STRIP_FLAG) $$list2 '$(DESTDIR)$(RestFrameslibdir)'"; \
	  $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=install $(INSTALL) $(INSTALL_STRIP_FLAG) $$list2 "$(DESTDIR)$(RestFrameslibdir)"; \
	}

uninstall-RestFrameslibLTLIBRARIES:
	@$(NORMAL_UNINSTALL)
	@list='$(RestFrameslib_LTLIBRARIES)'; test -n "$(RestFrameslibdir)" || list=; \
	for p in $$list; do \
	  $(am__strip_dir) \
	  echo " $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f '$(DESTDIR)$(RestFrameslibdir)/$$f'"; \
	  $(LIBTOOL) $(AM_LIBTOOLFLAGS) $(LIBTOOLFLAGS) --mode=uninstall rm -f "$(DESTDIR)$(RestFrameslibdir)/$$f"; \
	done

clean-RestFrameslibLTLIBRARIES:
	-test -z "$(RestFrameslib_LTLIBRARIES)" || rm -f $(RestFrameslib_LTLIBRARIES)
	@list='$(RestFrameslib_LTLIBRARIES)'; \
	locs=`for p in $$list; do echo $$p; done | \
	      sed 's|^[^/]*$$|.|; s|/[^/]*$$||; s|$$|/so_locations|' | \
	      sort -u`; \
	test -z "$$locs" || { \
	  echo rm -f $${locs}; \
	  rm -f $${locs}; \
	}

